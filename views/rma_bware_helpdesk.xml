<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_helpdesk_ticket_form_inherit_rma_bware" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.inherit.rma.bware</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="action_rma_bware_assign_to_me"
                        string="Zuweisen"
                        type="object"
                        class="btn-secondary"
                        invisible="not rma_is_bware_ticket or user_id"/>
                <button name="action_rma_bware_start"
                        string="Arbeit starten"
                        type="object"
                        class="btn-secondary"
                        invisible="not rma_is_bware_ticket or not user_id or rma_decision"/>
                <button name="action_rma_bware_finish_qs"
                        string="QS abgeschlossen"
                        type="object"
                        class="oe_highlight"
                        invisible="not rma_is_bware_ticket or rma_decision"/>
                <button name="action_rma_bware_decide_resale"
                        string="Wiederverkauf"
                        type="object"
                        class="oe_highlight"
                        invisible="not rma_is_bware_ticket or rma_decision"/>
                <button name="action_rma_bware_decide_scrap"
                        string="Schrottlager"
                        type="object"
                        class="btn-secondary"
                        invisible="not rma_is_bware_ticket or rma_decision"/>
                <button name="action_rma_bware_decide_repair"
                        string="Reparatur"
                        type="object"
                        class="btn-secondary"
                        invisible="not rma_is_bware_ticket or rma_decision"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <field name="rma_is_bware_ticket" invisible="1"/>
            </xpath>
            <xpath expr="//notebook/page[@name='description']" position="after">
                <page string="RMA B-Ware" name="rma_bware" invisible="not rma_is_bware_ticket">
                    <group>
                        <group string="Artikel">
                            <field name="rma_product_id"/>
                            <field name="rma_product_default_code"/>
                            <field name="rma_product_categ_id"/>
                            <field name="rma_bware_quantity"/>
                            <field name="rma_product_uom_id"/>
                            <field name="rma_unit_price"/>
                            <field name="rma_total_value"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Rückgabe">
                            <field name="rma_reason_id"/>
                            <field name="rma_sale_order_id"/>
                            <field name="rma_rma_picking_id"/>
                            <field name="rma_bware_picking_id"/>
                            <field name="rma_due_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Zeitdaten">
                            <field name="rma_purchase_date"/>
                            <field name="rma_delivery_date"/>
                            <field name="rma_return_date"/>
                            <field name="rma_days_since_purchase"/>
                            <field name="rma_days_since_delivery"/>
                        </group>
                        <group string="Entscheidung">
                            <field name="rma_decision"/>
                            <field name="rma_decision_note"/>
                            <field name="rma_target_location_id"/>
                            <field name="rma_decision_picking_id"/>
                            <field name="rma_decision_user_id"/>
                            <field name="rma_decision_date"/>
                        </group>
                    </group>
                </page>
                <page string="QS-Prüfung" name="rma_bware_qs" invisible="not rma_is_bware_ticket">
                    <group>
                        <group>
                            <field name="rma_functional_ok"/>
                            <field name="rma_cosmetic_defects"/>
                            <field name="rma_cosmetic_description" invisible="not rma_cosmetic_defects"/>
                            <field name="rma_missing_parts"/>
                            <field name="rma_missing_parts_description" invisible="not rma_missing_parts"/>
                        </group>
                        <group>
                            <field name="rma_inspection_date"/>
                            <field name="rma_inspection_notes"/>
                            <field name="rma_scrap_reason"/>
                            <field name="rma_scrap_cost"/>
                            <field name="rma_repair_description"/>
                            <field name="rma_repair_cost"/>
                            <field name="rma_repair_partner_id"/>
                        </group>
                    </group>
                </page>
                <page string="RMA Bilder / Anhänge" name="rma_bware_attachments" invisible="not rma_is_bware_ticket">
                    <field name="rma_attachment_ids" widget="many2many_binary" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_helpdesk_ticket_search_inherit_rma_bware" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search.inherit.rma.bware</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_tickets_view_search"/>
        <field name="arch" type="xml">
            <filter name="is_open" position="before">
                <filter string="RMA B-Ware" name="rma_bware" domain="[('rma_is_bware_ticket', '=', True)]"/>
                <filter string="Entscheidung ausstehend" name="rma_bware_decision" domain="[('rma_is_bware_ticket', '=', True), ('rma_decision', '=', False), ('kanban_state', '=', 'blocked')]"/>
            </filter>
            <filter name="partner" position="after">
                <filter string="RMA-Grund" name="group_by_rma_reason" context="{'group_by': 'rma_reason_id'}"/>
                <filter string="RMA Artikel" name="group_by_rma_product" context="{'group_by': 'rma_product_id'}"/>
            </filter>
        </field>
    </record>

    <record id="view_helpdesk_ticket_list_rma_bware" model="ir.ui.view">
        <field name="name">helpdesk.ticket.list.rma.bware</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list string="B-Ware Tickets" create="false">
                <field name="ticket_ref"/>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="rma_product_id"/>
                <field name="rma_bware_quantity"/>
                <field name="rma_reason_id"/>
                <field name="rma_due_date"/>
                <field name="rma_decision"/>
            </list>
        </field>
    </record>

    <record id="action_rma_bware_helpdesk_tickets" model="ir.actions.act_window">
        <field name="name">B-Ware Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('rma_is_bware_ticket', '=', True)]</field>
        <field name="context">{'search_default_rma_bware': 1, 'search_default_group_by_stage': 1}</field>
        <field name="search_view_id" ref="helpdesk.helpdesk_tickets_view_search"/>
        <field name="views" eval="[(ref('helpdesk.helpdesk_ticket_view_kanban'), 'kanban'), (ref('view_helpdesk_ticket_list_rma_bware'), 'list'), (ref('helpdesk.helpdesk_ticket_view_form'), 'form')]"/>
    </record>

    <menuitem id="menu_rma_bware_helpdesk_tickets"
              name="B-Ware Tickets"
              parent="menu_rma_management_root"
              action="action_rma_bware_helpdesk_tickets"
              groups="rma_management.group_rma_qs_inspector,rma_management.group_rma_manager"
              sequence="40"/>
</odoo>
