<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Basis-Layout für öffentliche RMA-Seiten (standalone, kein Portal-Login nötig) -->
    <template id="rma_portal_layout" name="RMA Portal Layout">
        <html lang="de">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title>RMA-Anfrage</title>
                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
                <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
                <style>
                    body { background: #f5f6f8; min-height: 100vh; }
                    .rma-navbar { background: #714b67; }
                    .rma-card {
                        background: #fff;
                        border-radius: 12px;
                        box-shadow: 0 2px 16px rgba(0,0,0,.08);
                        padding: 2rem;
                    }
                    .rma-header {
                        background: #714b67;
                        color: #fff;
                        border-radius: 12px 12px 0 0;
                        padding: 1.5rem 2rem;
                        margin: -2rem -2rem 1.5rem;
                    }
                    .rma-header h2 { margin: 0; font-size: 1.4rem; font-weight: 600; }
                    .rma-header p  { margin: .25rem 0 0; opacity: .8; font-size: .9rem; }
                    .rma-step-badge {
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        width: 2rem; height: 2rem;
                        border-radius: 50%;
                        background: rgba(255,255,255,.25);
                        font-weight: 700;
                        margin-right: .5rem;
                        font-size: .85rem;
                    }
                    .qty-input { width: 90px; }
                    .product-row { border-bottom: 1px solid #eee; padding: .75rem 0; }
                    .product-row:last-child { border-bottom: none; }
                </style>
            </head>
            <body>
                <nav class="rma-navbar navbar mb-4">
                    <div class="container">
                        <span class="navbar-brand text-white fw-bold">
                            <i class="fa fa-undo me-2"/>RMA-Portal
                        </span>
                    </div>
                </nav>
                <div class="container pb-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-7 col-md-9">
                            <t t-out="0"/>
                        </div>
                    </div>
                </div>
            </body>
        </html>
    </template>

    <!-- ── Schritt 1: Verifizierung ─────────────────────────────────────────── -->
    <template id="rma_portal_step1" name="RMA Anfrage – Schritt 1">
        <t t-call="rma_management.rma_portal_layout">
            <div class="rma-card">
                <div class="rma-header">
                    <h2>
                        <span class="rma-step-badge">1</span>
                        RMA-Anfrage stellen
                    </h2>
                    <p>Geben Sie Ihre E-Mail-Adresse und die Rechnungsnummer ein, um eine Rückgabe zu beantragen.</p>
                </div>

                <t t-if="error">
                    <div class="alert alert-danger d-flex gap-2 align-items-center" role="alert">
                        <i class="fa fa-exclamation-circle" title="Fehler"/>
                        <span t-esc="error"/>
                    </div>
                </t>

                <form action="/rma/anfrage/verify" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="email">E-Mail-Adresse</label>
                        <input type="email"
                               class="form-control form-control-lg"
                               id="email"
                               name="email"
                               placeholder="max.mustermann@firma.de"
                               t-att-value="email or ''"
                               required="required"/>
                        <div class="form-text">Die E-Mail-Adresse aus Ihrer Rechnung.</div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold" for="invoice_number">Rechnungsnummer</label>
                        <input type="text"
                               class="form-control form-control-lg"
                               id="invoice_number"
                               name="invoice_number"
                               placeholder="z.B. INV/2024/00123"
                               t-att-value="invoice_number or ''"
                               required="required"
                               style="text-transform:uppercase;"/>
                        <div class="form-text">Die Rechnungsnummer finden Sie oben rechts auf Ihrer Rechnung.</div>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fa fa-arrow-right me-2" title="Weiter"/>Weiter
                        </button>
                    </div>
                </form>

                <hr class="my-4"/>
                <p class="text-muted text-center mb-0" style="font-size:.875rem;">
                    <i class="fa fa-lock me-1" title="Sicher"/>
                    Ihre Daten werden nur zur Bearbeitung Ihrer Rückgabe verwendet.
                </p>
            </div>
        </t>
    </template>

    <!-- ── Schritt 2: Artikel und Grund auswählen ───────────────────────────── -->
    <template id="rma_portal_step2" name="RMA Anfrage – Schritt 2">
        <t t-call="rma_management.rma_portal_layout">
            <div class="rma-card">
                <div class="rma-header">
                    <h2>
                        <span class="rma-step-badge">2</span>
                        Rückgabe erfassen
                    </h2>
                    <p>
                        Rechnung <strong t-esc="invoice.name"/> ·
                        <span t-esc="partner.name"/>
                    </p>
                </div>

                <t t-if="error">
                    <div class="alert alert-danger d-flex gap-2 align-items-center" role="alert">
                        <i class="fa fa-exclamation-circle" title="Fehler"/>
                        <span t-esc="error"/>
                    </div>
                </t>

                <form action="/rma/anfrage/submit" method="post">
                    <!-- Rückgabegrund -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="reason_id">Rückgabegrund <span class="text-danger">*</span></label>
                        <select class="form-select" id="reason_id" name="reason_id" required="required">
                            <option value="">— Bitte wählen —</option>
                            <t t-foreach="reasons" t-as="reason">
                                <option t-att-value="reason.id"
                                        t-att-selected="str(post.get('reason_id','')) == str(reason.id) if post else None">
                                    <t t-esc="reason.name"/>
                                </option>
                            </t>
                        </select>
                    </div>

                    <!-- Artikel aus der Rechnung -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Artikel und Rückgabemengen <span class="text-danger">*</span></label>
                        <div class="border rounded p-3">
                            <div class="row fw-semibold text-muted mb-2 d-none d-md-flex" style="font-size:.8rem;">
                                <div class="col-md-5">Artikel</div>
                                <div class="col-md-2 text-end">Berechnet</div>
                                <div class="col-md-2 text-center">Rückgabe</div>
                                <div class="col-md-3">Bemerkung</div>
                            </div>
                            <t t-foreach="invoice_lines" t-as="line">
                                <div class="product-row row align-items-center">
                                    <div class="col-md-5 mb-2 mb-md-0">
                                        <span class="fw-semibold" t-esc="line.product_id.name"/>
                                        <t t-if="line.product_id.default_code">
                                            <small class="text-muted ms-1">(<t t-esc="line.product_id.default_code"/>)</small>
                                        </t>
                                    </div>
                                    <div class="col-md-2 text-md-end mb-2 mb-md-0">
                                        <span t-esc="line.quantity"/>
                                        <small class="text-muted" t-esc="line.product_uom_id.name"/>
                                    </div>
                                    <div class="col-md-2 text-md-center mb-2 mb-md-0">
                                        <input type="number"
                                               class="form-control form-control-sm qty-input"
                                               t-att-name="'qty_' + str(line.id)"
                                               min="0"
                                               t-att-max="line.quantity"
                                               step="1"
                                               placeholder="0"
                                               t-att-value="post.get('qty_' + str(line.id), '') if post else ''"/>
                                    </div>
                                    <div class="col-md-3">
                                        <input type="text"
                                               class="form-control form-control-sm"
                                               t-att-name="'note_' + str(line.id)"
                                               placeholder="Bemerkung …"
                                               t-att-value="post.get('note_' + str(line.id), '') if post else ''"/>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div class="form-text">Tragen Sie nur bei den Artikeln eine Menge ein, die Sie zurückgeben möchten.</div>
                    </div>

                    <!-- Beschreibung -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold" for="description">Problembeschreibung</label>
                        <textarea class="form-control"
                                  id="description"
                                  name="description"
                                  rows="3"
                                  placeholder="Beschreiben Sie das Problem oder den Defekt …"><t t-esc="post.get('description','') if post else ''"/></textarea>
                    </div>

                    <div class="d-flex gap-2 justify-content-between">
                        <a href="/rma/anfrage" class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1" title="Zurück"/> Zurück
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg px-4">
                            <i class="fa fa-paper-plane me-2" title="Absenden"/>RMA beantragen
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>

    <!-- ── Schritt 3: Bestätigung ────────────────────────────────────────────── -->
    <template id="rma_portal_confirm" name="RMA Anfrage – Bestätigung">
        <t t-call="rma_management.rma_portal_layout">
            <div class="rma-card text-center">
                <div class="mb-4">
                    <div style="width:72px;height:72px;background:#28a745;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                        <i class="fa fa-check fa-2x text-white" title="Erfolgreich"/>
                    </div>
                    <h3 class="fw-bold">Ihre Anfrage wurde eingereicht!</h3>
                    <p class="text-muted">Wir bearbeiten Ihre Rückgabeanfrage und melden uns bei Ihnen.</p>
                </div>

                <div class="border rounded p-3 mb-4 text-start">
                    <div class="row g-2">
                        <div class="col-sm-4 text-muted">Anfrage-Nr.</div>
                        <div class="col-sm-8 fw-semibold" t-esc="portal_request.name"/>
                        <div class="col-sm-4 text-muted">Rechnung</div>
                        <div class="col-sm-8" t-esc="invoice.name"/>
                        <div class="col-sm-4 text-muted">Rückgabegrund</div>
                        <div class="col-sm-8" t-esc="portal_request.rma_reason_id.name"/>
                        <div class="col-sm-4 text-muted">Status</div>
                        <div class="col-sm-8">
                            <span class="badge bg-primary">Eingereicht</span>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="fw-semibold mb-2">Eingereichte Positionen</h6>
                    <table class="table table-sm text-start">
                        <thead class="table-light">
                            <tr>
                                <th>Artikel</th>
                                <th class="text-end">Menge</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="portal_request.line_ids" t-as="line">
                                <tr>
                                    <td t-esc="line.product_id.name"/>
                                    <td class="text-end" t-esc="line.qty_requested"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <p class="text-muted mb-4" style="font-size:.875rem;">
                    Bitte verpacken Sie die Artikel sicher. Sie erhalten weitere Anweisungen von uns.
                </p>

                <a href="/rma/anfrage" class="btn btn-outline-primary">
                    Weitere Anfrage stellen
                </a>
            </div>
        </t>
    </template>
</odoo>
