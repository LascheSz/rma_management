<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_rma_portal_request_list" model="ir.ui.view">
        <field name="name">rma.portal.request.list</field>
        <field name="model">rma.portal.request</field>
        <field name="arch" type="xml">
            <list string="Portal-Anfragen"
                  create="false"
                  decoration-info="state == 'submitted'"
                  decoration-warning="state in ('approved', 'processing')"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'rejected'">
                <field name="name" string="Anfrage-Nr."/>
                <field name="create_date" string="Eingereicht"/>
                <field name="partner_id" string="Kunde"/>
                <field name="invoice_id" string="Rechnung"/>
                <field name="rma_reason_id" string="Rückgabegrund"/>
                <field name="state" string="Status"
                       widget="badge"
                       decoration-info="state == 'submitted'"
                       decoration-warning="state in ('approved', 'processing')"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'rejected'"/>
                <field name="picking_id" string="RMA-Eingang" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_rma_portal_request_form" model="ir.ui.view">
        <field name="name">rma.portal.request.form</field>
        <field name="model">rma.portal.request</field>
        <field name="arch" type="xml">
            <form string="Portal-RMA-Anfrage">
                <header>
                    <button name="action_approve"
                            string="Genehmigen &amp; E-Mail senden"
                            type="object"
                            class="oe_highlight"
                            icon="fa-check"
                            invisible="state != 'submitted'"
                            groups="rma_management.group_rma_user"/>
                    <button name="action_mark_done"
                            string="Als erledigt markieren"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'processing'"
                            groups="rma_management.group_rma_user"/>
                    <button name="action_reject"
                            string="Ablehnen"
                            type="object"
                            invisible="state not in ('submitted', 'approved')"
                            groups="rma_management.group_rma_user"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="submitted,approved,processing,done"/>
                </header>
                <sheet>
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="fa fa-inbox fa-2x text-primary" title="Portal-Anfrage"/>
                        <div>
                            <h4 class="mb-0">Portal-RMA-Anfrage <field name="name" readonly="1" class="ms-1 fs-6 fw-normal text-muted" nolabel="1"/></h4>
                            <small class="text-muted">Vom Kunden über das RMA-Portal eingereicht</small>
                        </div>
                    </div>

                    <!-- Hinweis nach Genehmigung -->
                    <div class="alert alert-success d-flex gap-2 align-items-start"
                         role="alert"
                         invisible="state not in ('approved', 'processing')">
                        <i class="fa fa-check-circle fa-lg mt-1" title="Genehmigt"/>
                        <div>
                            <strong>Anfrage genehmigt — Kunde wurde per E-Mail informiert.</strong>
                            <span invisible="state != 'approved'">
                                Sobald die Ware eingetroffen ist, in der
                                <strong>RMA-Erstellung</strong> diese Anfrage auswählen.
                            </span>
                            <span invisible="state != 'processing'">
                                RMA-Eingang <field name="picking_id" readonly="1" nolabel="1" class="fw-semibold"/> wurde angelegt.
                            </span>
                        </div>
                    </div>

                    <group>
                        <group string="Kundendaten">
                            <field name="partner_id" readonly="1"/>
                            <field name="invoice_id" readonly="1"/>
                            <field name="sale_order_id" readonly="1" invisible="not sale_order_id"/>
                        </group>
                        <group string="Anfrage">
                            <field name="rma_reason_id"/>
                            <field name="create_date" readonly="1" string="Eingereicht am"/>
                        </group>
                    </group>

                    <group string="Problembeschreibung" invisible="not description">
                        <field name="description" nolabel="1" readonly="1"/>
                    </group>

                    <group string="Ablehnungsgrund" invisible="state != 'rejected'">
                        <field name="rejection_reason" nolabel="1"/>
                    </group>

                    <separator string="Vom Kunden angegebene Rückgabepositionen"/>
                    <field name="line_ids" readonly="1" nolabel="1">
                        <list create="false" delete="false">
                            <field name="product_id" string="Artikel"/>
                            <field name="qty_invoiced" string="Berechnet"/>
                            <field name="qty_requested" string="Gewünschte Rückgabemenge"/>
                            <field name="note" string="Kundenbemerkung"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_rma_portal_request_search" model="ir.ui.view">
        <field name="name">rma.portal.request.search</field>
        <field name="model">rma.portal.request</field>
        <field name="arch" type="xml">
            <search string="Portal-Anfragen">
                <field name="name" string="Anfrage-Nr."/>
                <field name="partner_id" string="Kunde"/>
                <field name="invoice_id" string="Rechnung"/>
                <separator/>
                <filter name="submitted" string="Eingereicht" domain="[('state','=','submitted')]"/>
                <filter name="approved" string="Genehmigt" domain="[('state','=','approved')]"/>
                <filter name="processing" string="In Bearbeitung" domain="[('state','=','processing')]"/>
                <filter name="done" string="Erledigt" domain="[('state','=','done')]"/>
                <filter name="rejected" string="Abgelehnt" domain="[('state','=','rejected')]"/>
                <separator/>
                <filter name="open" string="Offen" domain="[('state','in',['submitted','approved'])]"/>
                <separator/>
                <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                <filter name="group_partner" string="Kunde" context="{'group_by': 'partner_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_rma_portal_requests" model="ir.actions.act_window">
        <field name="name">Portal-Anfragen</field>
        <field name="res_model">rma.portal.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_rma_portal_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Noch keine Portal-Anfragen eingegangen.</p>
            <p>Kunden können unter <strong>/rma/anfrage</strong> eine Rückgabe beantragen.</p>
        </field>
    </record>

    <menuitem id="menu_rma_portal_requests"
              name="Portal-Anfragen"
              parent="menu_rma_management_root"
              action="action_rma_portal_requests"
              groups="rma_management.group_rma_user"
              sequence="25"/>
</odoo>
