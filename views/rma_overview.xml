<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Listenansicht -->
    <record id="view_rma_status_overview_list" model="ir.ui.view">
        <field name="name">stock.picking.rma.status.overview.list</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list string="RMA-Statusübersicht"
                  create="false"
                  decoration-success="rma_status == 'done'"
                  decoration-warning="rma_status == 'checked'"
                  decoration-muted="rma_status == 'cancel'">
                <field name="name" string="RMA Beleg"/>
                <field name="partner_id" string="Kunde"/>
                <field name="rma_reason_id" string="Grund"/>
                <field name="rma_status" string="Status" widget="badge"
                       decoration-success="rma_status == 'done'"
                       decoration-warning="rma_status == 'checked'"
                       decoration-info="rma_status == 'open'"
                       decoration-danger="rma_status == 'cancel'"/>
                <field name="origin" string="Referenz"/>
                <field name="scheduled_date" string="Geplantes Datum"/>
                <field name="state" string="Lagerstatus"/>
            </list>
        </field>
    </record>

    <!-- Kanban mit farbcodierten Status-Badges -->
    <record id="view_rma_status_overview_kanban" model="ir.ui.view">
        <field name="name">stock.picking.rma.status.overview.kanban</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <kanban default_group_by="rma_status" class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="rma_reason_id"/>
                <field name="rma_status"/>
                <field name="origin"/>
                <field name="scheduled_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <strong class="o_kanban_record_title fs-6">
                                    <i class="fa fa-undo me-1 text-muted"/>
                                    <field name="name"/>
                                </strong>
                                <!-- Status-Badge farbcodiert -->
                                <span t-if="record.rma_status.raw_value == 'open'"
                                      class="badge rounded-pill text-bg-primary">
                                    <i class="fa fa-clock-o me-1"/>Offen
                                </span>
                                <span t-if="record.rma_status.raw_value == 'checked'"
                                      class="badge rounded-pill text-bg-warning">
                                    <i class="fa fa-search me-1"/>Geprüft
                                </span>
                                <span t-if="record.rma_status.raw_value == 'done'"
                                      class="badge rounded-pill text-bg-success">
                                    <i class="fa fa-check me-1"/>Erledigt
                                </span>
                                <span t-if="record.rma_status.raw_value == 'cancel'"
                                      class="badge rounded-pill text-bg-secondary">
                                    <i class="fa fa-ban me-1"/>Abgebrochen
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-1 text-muted mb-1">
                                <i class="fa fa-user fa-fw"/>
                                <field name="partner_id"/>
                            </div>
                            <div class="d-flex align-items-center gap-1 text-muted mb-1" t-if="record.rma_reason_id.raw_value">
                                <i class="fa fa-tag fa-fw"/>
                                <field name="rma_reason_id"/>
                            </div>
                            <div class="d-flex align-items-center gap-1 text-muted" t-if="record.origin.raw_value">
                                <i class="fa fa-file-text-o fa-fw"/>
                                <field name="origin"/>
                            </div>
                            <div class="d-flex align-items-center gap-1 text-muted mt-1" t-if="record.scheduled_date.raw_value">
                                <i class="fa fa-calendar fa-fw"/>
                                <field name="scheduled_date"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Suchansicht -->
    <record id="view_rma_status_overview_search" model="ir.ui.view">
        <field name="name">stock.picking.rma.status.overview.search</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <search string="RMA-Statusübersicht">
                <field name="name" string="RMA Beleg"/>
                <field name="partner_id"/>
                <field name="origin"/>
                <field name="rma_reason_id"/>
                <separator/>
                <filter name="rma_open" string="Offen" domain="[('rma_status', '=', 'open')]"/>
                <filter name="rma_checked" string="Geprüft" domain="[('rma_status', '=', 'checked')]"/>
                <filter name="rma_done" string="Erledigt" domain="[('rma_status', '=', 'done')]"/>
                <filter name="rma_cancel" string="Abgebrochen" domain="[('rma_status', '=', 'cancel')]"/>
                <separator/>
                <filter name="group_by_rma_status" string="Status" context="{'group_by': 'rma_status'}"/>
                <filter name="group_by_rma_reason" string="Grund" context="{'group_by': 'rma_reason_id'}"/>
                <filter name="group_by_partner" string="Kunde" context="{'group_by': 'partner_id'}"/>
            </search>
        </field>
    </record>

    <!-- Smart-Button und RMA-Erstellen-Button auf dem Verkaufsauftrag -->
    <record id="view_sale_order_form_inherit_rma_button" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.rma.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="rma_eligible" invisible="1"/>
                <button name="action_view_rmas"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-undo"
                        invisible="rma_count == 0"
                        groups="rma_management.group_rma_user">
                    <field name="rma_open_count" invisible="1"/>
                    <div class="o_stat_info">
                        <field name="rma_count" class="o_stat_value"/>
                        <span class="o_stat_text" invisible="rma_open_count == 0">RMA</span>
                        <span class="o_stat_text text-warning" invisible="rma_open_count == 0">
                            (<field name="rma_open_count"/> offen)
                        </span>
                        <span class="o_stat_text" invisible="rma_open_count != 0">RMA</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//button[@name='action_cancel']" position="after">
                <button name="action_create_rma"
                        string="RMA erstellen"
                        type="object"
                        invisible="not rma_eligible"
                        groups="rma_management.group_rma_user"/>
            </xpath>
        </field>
    </record>

    <record id="action_rma_status_overview" model="ir.actions.act_window">
        <field name="name">RMA-Übersicht</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">kanban,list,graph,pivot,form</field>
        <field name="domain">[('rma_is_receipt', '=', True)]</field>
        <field name="context">{'search_default_group_by_rma_status': 1}</field>
        <field name="search_view_id" ref="view_rma_status_overview_search"/>
        <field name="views" eval="[
            (ref('view_rma_status_overview_kanban'), 'kanban'),
            (ref('view_rma_status_overview_list'), 'list'),
            (ref('view_rma_overview_graph'), 'graph'),
            (ref('view_rma_overview_pivot'), 'pivot'),
            (False, 'form'),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Noch keine RMA-Eingänge vorhanden.</p>
        </field>
    </record>

    <menuitem id="menu_rma_status_overview"
              name="Statusübersicht"
              parent="menu_rma_management_root"
              action="action_rma_status_overview"
              groups="rma_management.group_rma_user"
              sequence="30"/>
</odoo>
