<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Read-only Liste aller automatisch protokollierten RMA-Ereignisse. -->
    <record id="view_rma_audit_log_list" model="ir.ui.view">
        <field name="name">rma.audit.log.list</field>
        <field name="model">rma.audit.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="create_date" string="Zeitpunkt"/>
                <field name="action"/>
                <field name="name"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="sale_order_id"/>
                <field name="picking_id"/>
            </list>
        </field>
    </record>

    <!-- Detailansicht fuer Audit-Texte und referenzierte Belege. -->
    <record id="view_rma_audit_log_form" model="ir.ui.view">
        <field name="name">rma.audit.log.form</field>
        <field name="model">rma.audit.log</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <field name="action"/>
                        <field name="name"/>
                        <field name="user_id"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="sale_order_id"/>
                        <field name="picking_id"/>
                        <field name="generated_picking_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Details">
                        <field name="details" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Suche nach Aktion, Benutzer, Kunde und betroffenen Belegen. -->
    <record id="view_rma_audit_log_search" model="ir.ui.view">
        <field name="name">rma.audit.log.search</field>
        <field name="model">rma.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="picking_id"/>
                <field name="partner_id"/>
                <filter name="group_by_action" string="Aktion" context="{'group_by': 'action'}"/>
                <filter name="group_by_user" string="Benutzer" context="{'group_by': 'user_id'}"/>
            </search>
        </field>
    </record>

    <!-- Separate Audit-Aktion, zusätzlich zu den Chatter-Einträgen am Beleg. -->
    <record id="action_rma_audit_log" model="ir.actions.act_window">
        <field name="name">Audit-Log</field>
        <field name="res_model">rma.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_by_action': 1}</field>
    </record>

    <!-- Audit ist im RMA-Menü sichtbar, aber unveränderlich. -->
    <menuitem id="menu_rma_audit_log"
              name="Audit-Log"
              parent="menu_rma_management_root"
              action="action_rma_audit_log"
              groups="rma_management.group_rma_user"
              sequence="90"/>
</odoo>
