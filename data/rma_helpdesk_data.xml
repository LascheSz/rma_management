<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <!-- Standard-Team und Stufen für B-Ware-QS-Tickets im Helpdesk. -->
    <record id="helpdesk_team_rma_bware_qs" model="helpdesk.team">
        <field name="name">RMA B-Ware QS</field>
        <field name="alias_name">rma-bware-qs</field>
        <field name="privacy_visibility">internal</field>
        <field name="use_sla" eval="True"/>
        <field name="member_ids" eval="[Command.link(ref('base.user_admin'))]"/>
    </record>

    <record id="helpdesk_stage_rma_bware_new" model="helpdesk.stage">
        <field name="name">Neu</field>
        <field name="sequence">10</field>
        <field name="team_ids" eval="[Command.link(ref('helpdesk_team_rma_bware_qs'))]"/>
    </record>
    <record id="helpdesk_stage_rma_bware_assigned" model="helpdesk.stage">
        <field name="name">Zugewiesen</field>
        <field name="sequence">20</field>
        <field name="team_ids" eval="[Command.link(ref('helpdesk_team_rma_bware_qs'))]"/>
    </record>
    <record id="helpdesk_stage_rma_bware_progress" model="helpdesk.stage">
        <field name="name">In Bearbeitung</field>
        <field name="sequence">30</field>
        <field name="team_ids" eval="[Command.link(ref('helpdesk_team_rma_bware_qs'))]"/>
    </record>
    <record id="helpdesk_stage_rma_bware_decision" model="helpdesk.stage">
        <field name="name">Entscheidung ausstehend</field>
        <field name="sequence">40</field>
        <field name="team_ids" eval="[Command.link(ref('helpdesk_team_rma_bware_qs'))]"/>
        <field name="legend_blocked">Entscheidung erforderlich</field>
    </record>
    <record id="helpdesk_stage_rma_bware_done" model="helpdesk.stage">
        <field name="name">Abgeschlossen</field>
        <field name="sequence">50</field>
        <field name="fold" eval="True"/>
        <field name="team_ids" eval="[Command.link(ref('helpdesk_team_rma_bware_qs'))]"/>
    </record>
</odoo>
